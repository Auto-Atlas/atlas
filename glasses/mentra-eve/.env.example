# ---- EVE hub contract ----
# REST base of the EVE API hub (this box). No trailing slash.
EVE_API_URL=http://127.0.0.1:8799
# Optional: explicit WS stream URL. If omitted it is derived from EVE_API_URL
# (http->ws, https->wss) as ${host}/v1/stream.
# EVE_WS_URL=ws://127.0.0.1:8799/v1/stream
# Shared bearer token: used for EVE REST + WS auth AND to authenticate inbound
# POST /narrate calls. Must match what the EVE side is configured with.
EVE_APP_TOKEN=replace-with-shared-token

# ---- MentraOS app identity (from console.mentra.glass) ----
PACKAGE_NAME=com.yourorg.evementra
MENTRAOS_API_KEY=replace-with-mentraos-api-key
# Port this app's HTTP server (MentraOS webhook + /narrate) listens on.
PORT=7010

# ---- Tuning knobs (all optional; defaults shown) ----
# EVE WS reconnect backoff
EVE_RECONNECT_BASE_MS=500
EVE_RECONNECT_MAX_MS=30000
EVE_RECONNECT_FACTOR=2
# Frame POST retries
EVE_FRAME_POST_RETRIES=3
EVE_FRAME_POST_RETRY_MS=500
# Hard cap on a captured JPEG we will POST to EVE (bytes). Default 8 MiB.
EVE_MAX_FRAME_BYTES=8388608
