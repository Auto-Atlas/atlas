# Copy this file to ".env" and edit. LOCAL mode needs ZERO keys.
#
# NAMING: settings here use the public ATLAS_ prefix. Every ATLAS_ name is
# also accepted under its historical EVE_/JARVIS_ name (and vice versa) —
# atlas_env.py maps them at startup, and an explicitly-set legacy name always
# wins. Existing installs need to change nothing.

# ---------- MODE ----------
# local    = faster-whisper + Ollama + Kokoro. Free, no keys, runs on your 5070.
# showtime = Deepgram + OpenAI + Cartesia. Premium voice for the wow demo.
ATLAS_MODE=local

# ---------- LOCAL MODE (no keys needed) ----------
# qwen3:8b is the verified tool-caller for the voice loop (llama3.1:8b emitted
# duplicate tool calls and fabricated results).
OLLAMA_MODEL=qwen3:8b
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=300
KOKORO_VOICE=af_heart
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16

# ---------- SHOWTIME MODE (only read when ATLAS_MODE=showtime) ----------
# Leave blank unless you flip to showtime. Get keys from each provider's dashboard.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
SHOWTIME_LLM_MODEL=gpt-4o
CARTESIA_API_KEY=
CARTESIA_VOICE=71a7ad14-091c-4e8e-a314-022ece01c121  # public Cartesia preset (not a personal voice)

# ---------- UI bridge (openjarvis connects here) ----------
# ATLAS_WS_PORT is the desktop metrics/UI websocket (bot.py serves it; the
# OpenJarvis desktop UI connects here). NOT the phone voice port — see
# ATLAS_PHONE_PORT below. Keep these three ports distinct:
#   8765 = ATLAS_WS_PORT      (desktop UI websocket bridge)
#   8788 = ATLAS_PHONE_PORT   (phone_bot.py WebRTC voice signaling, loopback)
#   8789 = OAuth callback      (connectors/oauth.py local redirect; not set here)
ATLAS_WS_HOST=127.0.0.1
ATLAS_WS_PORT=8765

# ---------- phone voice loop (phone_bot.py WebRTC) ----------
# phone_bot.py binds 127.0.0.1:8788 and is exposed over the tailnet with
#   tailscale serve --bg --https=8444 http://localhost:8788
# Override only if 8788 is taken on your box. This is the phone voice port and
# is deliberately NOT 8789 (8789 is the connectors OAuth redirect callback).
ATLAS_PHONE_PORT=8788

# ---------- identity (multi-tenant: YOUR name, YOUR assistant) ----------
# All optional. The user name normally comes from onboarding (the life
# dashboard / the phone app wizard); these env vars override it.
# ATLAS_ASSISTANT_NAME=Atlas   # what the assistant calls itself (default Atlas)
# ATLAS_USER_NAME=             # your name (default: life dashboard "user")
# ATLAS_USER_NICK=             # what it calls you aloud (default: first name)

# ---------- voice brain profiles ----------
# The active voice LLM is a named profile: settings-store "voice_brain" (app
# toggle) -> ATLAS_VOICE_BRAIN env -> the ATLAS_LLM_* legacy vars -> ollama.
# Builtins: ollama | zai | zai-openai. Add YOUR OWN endpoints (a vLLM rig on
# your tailnet, a lab box) in a gitignored brains.local.json next to
# voice_llm.py — same shape as BUILTIN_PROFILES:
#   {"my-rig": {"api": "vllm", "base_url": "http://my-rig:8080/v1", "model": "Qwen3.5-122B-A10B"}}
# ATLAS_VOICE_BRAIN=ollama
# ATLAS_BRAINS_FILE=              # override the brains file location

# ---------- sales coach business pack ----------
# The coach grounds itself in YOUR real offers/prices/objections, written by
# you to a gitignored markdown file. Without it the coach refuses to run.
# ATLAS_BUSINESS_CONTEXT=         # default: business_context.md next to sales_coach.py

# ---------- agent brains (jarvis_agent tool) ----------
# Headless Claude Code flags for the "claude" brain. Point --mcp-config at a
# .mcp.json of MCP servers that work WITHOUT interactive auth (local stdio
# servers with stored tokens). --allowedTools pre-approves them headless.
# ATLAS_CLAUDE_ARGS=--permission-mode acceptEdits --output-format json --mcp-config <path>\.mcp.json --allowedTools mcp__<server>

# "acp" brain: Claude Code over the Agent Client Protocol — acpx (npm install
# -g acpx) drives acp_claude_code.py, which runs `claude --bg` background
# sessions on the CLI's subscription OAuth. No `claude -p`, no API key (the
# adapter strips ANTHROPIC_API_KEY from the child env). Leads the default
# coding chain; pin/reorder with ATLAS_BRAIN_ORDER (e.g. "acp,codex,local").
# ATLAS_ACPX_BIN=acpx
# ATLAS_ACP_ADAPTER=/path/to/atlas/acp_claude_code.py
# ATLAS_ACP_PYTHON=            # interpreter for the adapter (default: current)
# ATLAS_ACP_SESSION=eve        # persistent named acpx session for delegations
# Adapter knobs (read by acp_claude_code.py itself):
# ATLAS_ACP_CLAUDE_BIN=claude
# ATLAS_ACP_PERMISSION_MODE=acceptEdits
# ATLAS_ACP_MODEL=                # e.g. sonnet / opus / full model id
# ATLAS_ACP_EFFORT=               # low|medium|high|xhigh|max
# ATLAS_ACP_CLAUDE_ARGS=--strict-mcp-config
# ATLAS_ACP_WORKSPACE=~/jarvis-workspace
# ATLAS_ACP_SESSION_PREFIX=eve-acp
# ATLAS_ACP_TURN_TIMEOUT_S=600
# ATLAS_ACP_ALLOW_API_KEY=0       # 1 = permit ambient ANTHROPIC_API_KEY (API billing)
# Mid-task talk-back (notify_eve/ask_eve from inside the Claude session):
# run scripts/setup_acp_talkback.sh, it generates the MCP config and prints
# this line (comma form — --allowedTools is variadic, space-separated names
# would swallow the prompt):
# ATLAS_ACP_TALKBACK_CLAUDE_ARGS=--mcp-config <repo>/acp-talkback.mcp.json --allowedTools mcp__eve__notify_eve,mcp__eve__ask_eve
# ATLAS_ACP_TALKBACK_REQUESTER=eve-voice
# ATLAS_ACP_TALKBACK_TIER=owner
# ATLAS_ACP_TALKBACK_TTL_S=3600
# Goal-locked delegations: each task is sent as "/goal <task>" so the session's
# goal Stop-hook keeps Claude working until the condition holds. Needs your
# /goal command; goal-locked runs run long — give the tier its own budget.
# ATLAS_ACP_GOAL_PREFIX=/goal
# ATLAS_ACP_TIMEOUT=900

# ---------- home location (weather + future location-aware tools) ----------
ATLAS_HOME_LAT=
ATLAS_HOME_LON=
ATLAS_HOME_PLACE=

# ---------- texting (SMS Gate app on the phone, Local Server mode) ----------
# URL is the phone's tailnet IP + the port SMS Gate shows (default 8080).
# User/pass are displayed in the SMS Gate app's Local Server screen.
# ATLAS_OWNER_PHONE is your own number ("text me" resolves to it, and it
# gates the SMS self-command channel).
ATLAS_OWNER_PHONE=
ATLAS_SMS_GATEWAY_URL=
ATLAS_SMS_USER=
ATLAS_SMS_PASS=
# How a SELF-text is titled in Google Messages notifications (the MacroDroid
# bridge posts the notification title as the sender). Comma-separated, exact
# match, case-insensitive.
ATLAS_OWNER_NAMES=

# ---------- calendar (read-only, no OAuth) ----------
# Google Calendar -> gear -> Settings -> click your calendar (left sidebar) ->
# "Integrate calendar" -> copy "Secret address in iCal format" -> paste here.
ATLAS_CALENDAR_ICS_URL=

# ---------- email (read-only IMAP, no OAuth) ----------
# myaccount.google.com/apppasswords -> create one named "Jarvis" -> paste the
# 16-character code here (spaces are fine; they're stripped).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ---------- persistent memory ----------
# Markdown page where "remember" facts are appended and reloaded at boot.
ATLAS_MEMORY_PAGE=

# ---------- EVE Agent Hub (delegation to specialist agents) ----------
# EVE delegates tasks to specialist agents (Phase 1: Hermes, the messaging/comms agent)
# and pings you back asynchronously. All optional — sane defaults shown.
# Path to the Hermes CLI; auto-resolved via `which hermes`, override only if needed.
ATLAS_HERMES_BIN=
# Per-delegated-task wall-clock budget (s) before the poller gives up + a task's TTL (s).
ATLAS_DELEGATE_HARD_S=180
ATLAS_DELEGATE_TTL_S=14400
# Poller lease (s), poll interval (s), and max attempts before a task is marked abandoned.
ATLAS_DELEGATE_LEASE_S=300
ATLAS_DELEGATE_POLL_S=4
# ---- Two-way A2A comms fabric (optional; default OFF) ----
# When "1", delegate_hermes routes OVER A2A (a2a-sdk): EVE delegates to a Hermes A2A adapter and
# the adapter pushes results/blockers/questions back to EVE's inbound webhook. Off => the existing
# poller path is used, unchanged. Requires the Hermes adapter process to be running (see below).
ATLAS_A2A_ENABLED=
# The Hermes A2A adapter's base URL (the process running a2a_fabric.build_fabric_app()).
ATLAS_A2A_HERMES_URL=http://127.0.0.1:8790
# EVE's own inbound push URL that the adapter calls back — the loopback webhook (:8787) A2A route,
# including the webhook token path segment. The per-task HMAC callback_token is the real capability.
ATLAS_A2A_INBOUND_URL=
# Port the Hermes adapter process listens on (used to build its agent card).
ATLAS_A2A_PORT=8790
# Shared secret for the adapter (:8790): every route requires X-EVE-A2A-Key to match. With this
# unset the adapter fails CLOSED (403s everything) — it fronts `hermes -z --ignore-rules`.
ATLAS_A2A_ADAPTER_KEY=
# Agent talk-back (the MCP tools Hermes calls mid-run):
# how long ask_eve blocks waiting for the owner's answer (also shown in the notification).
ATLAS_TALKBACK_ASK_WAIT_S=840
# hermes run budget under the adapter (>= ask wait + work time; the poller keeps its own 180s).
ATLAS_TALKBACK_HARD_S=1800
# ask_eve answer-poll interval + per-HTTP-call timeout inside the MCP server.
ATLAS_TALKBACK_POLL_S=2
ATLAS_TALKBACK_HTTP_TIMEOUT_S=10
# minimum seconds between delivered progress updates per task (anti-spam).
ATLAS_TALKBACK_PROGRESS_COOLDOWN_S=30
# request-body cap (bytes) on the /agent/a2a/* routes (tailnet-reachable).
ATLAS_TALKBACK_MAX_BODY=262144
# ---------- Proactive calendar surfacing (on when the ICS url is set) ----------
# EVE watches the same read-only Google-Calendar ICS feed get_calendar uses and speaks/pushes:
# a reminder ~ATLAS_CAL_LEAD_MIN before each timed event, a morning look-ahead (today), and an
# evening look-ahead (tomorrow). No cron daemon — it's a task in EVE's own loop.
ATLAS_CAL_WATCH=1            # "0" disables the watcher entirely
ATLAS_CAL_LEAD_MIN=15        # minutes of warning before an event
ATLAS_CAL_POLL_S=120         # feed poll interval (seconds)
ATLAS_CAL_MORNING=08:00      # daily look-ahead times (24h HH:MM, local)
ATLAS_CAL_EVENING=20:00
# Calendar WRITE (add_calendar_event). PREFERRED: EVE's built-in "Connect Google Calendar" —
# put your own OAuth client below (any Google Cloud/Firebase project; docs/google-calendar.md),
# say "connect my calendar", approve once in the browser. Tokens: chmod-600 file on this box.
ATLAS_GOOGLE_CLIENT_ID=      # OAuth 2.0 client (Desktop app) from YOUR Google Cloud project
ATLAS_GOOGLE_CLIENT_SECRET=  # its secret; both unset => native path off
# ATLAS_GOOGLE_TOKEN_PATH=   # default ~/.eve/google_calendar_token.json
# ATLAS_GOOGLE_OAUTH_PORT=8792  # loopback consent callback port (8789-8791 already in use)
# Second choice: the OpenJarvis gcalendar connector (when that daemon runs alongside).
ATLAS_CAL_CONNECTOR=1        # "0" disables the connector probe
# LEGACY fallback: your own Apps Script webhook (docs/calendar-write.md).
ATLAS_CAL_WRITE_URL=         # legacy: deployed web-app URL (…/exec)
ATLAS_CAL_WRITE_TOKEN=       # legacy: the shared secret from the script's Script Properties
# Quiet hours for ping-backs (HH-HH, wraps midnight): inside this window a finished
# delegated task is NOT spoken aloud — EVE sends a notification with the answer headline.
# Unset = always speak (today's behavior). Example: 22-7
ATLAS_QUIET_HOURS=

# ---------- Initiative engine (unified proactive surfacing; spec 2026-07-02) ----------
# ONE loop owns "should EVE speak right now?": calendar nudges + daily rhythms (morning
# brief, evening look-ahead, Sunday week-ahead) + important-email alerts, scored against
# your persisted feedback ("don't tell me these" -> adjust_surfacing tool), quiet hours
# and a no-spam gap. When on, it replaces the standalone calendar watcher above.
ATLAS_INITIATIVE=1                 # "0" restores the standalone calendar watcher only
ATLAS_INITIATIVE_POLL_S=60         # engine tick interval (seconds)
ATLAS_INITIATIVE_MIN_GAP_S=180     # no-spam: min seconds between event-driven interruptions
ATLAS_INITIATIVE_EMAIL_POLL_S=300  # IMAP poll interval for proactive email surfacing
ATLAS_WEEK_AHEAD=17:00             # Sunday week-ahead brief time (24h HH:MM, local)
ATLAS_FOLLOWUP_DAYS=3              # open-loop lookback (days, excluding today) for follow-ups
ATLAS_FOLLOWUP_MAX=3               # max open-loop follow-ups surfaced per day

# ---------- Embodiment (the separate eve-embodiment platform; sim now, Jetson later) -----
# EVE's body as an MCP client: look/describe/sim_start/move/grasp — motion confirm-gated,
# estop instant, owner-only. Robot events surface as visual cards via the initiative
# engine. OFF by default until the owner flips it.
ATLAS_EMBODIMENT=0
# ATLAS_EMBODIMENT_CMD=            # default: uv --directory ~/eve-embodiment run embody mcp
# ATLAS_EMBODIMENT_EVENTS=         # default: repo/embodiment_events.jsonl
# ATLAS_INITIATIVE_PREFS=          # feedback prefs path (default: repo/initiative_prefs.json)

# ---------- Thinking toggle (manual on/off reasoning) ----------
# Default OFF (fast). Flip from the app, the sidecar UI 'THINK' chip, or by voice
# ("think this through" / "back to fast mode"). When ON, the voice LLM reasons.
# reasoning_effort used when thinking is ON (Ollama dialect):
ATLAS_THINKING_EFFORT=medium

# ---------- EVE mobile app + approval API (eve-app, approval_api.py) ----------
# Cross-tier shared bearer token for the EVE phone app. The approval API and the
# pairing endpoint refuse to start when this is blank AND approval_token.txt is
# absent/empty (fail-closed). Generate a real one (>=32 random bytes), e.g.:
#   head -c 32 /dev/urandom | base64
# The app sends it as "Authorization: Bearer <token>" on every request.
ATLAS_APP_TOKEN=
# Path to a file holding the token instead of the env var (default
# approval_token.txt next to the code). chmod 600 it. ATLAS_APP_TOKEN wins if both
# are set; otherwise the file's contents are used.
ATLAS_APP_TOKEN_FILE=
# Where approval_api.py binds. Stays loopback by default; expose over the tailnet
# with `tailscale serve`, never 0.0.0.0 without a reverse proxy.
ATLAS_APPROVAL_HOST=127.0.0.1
ATLAS_APPROVAL_PORT=8799
# SQLite store for pending approvals (created on first write).
ATLAS_APPROVAL_DB=          # default: approvals.db next to the code

# ---------- approval push (self-hosted ntfy, approval_push.py) ----------
# When an approval is pending, EVE pushes a high-priority ntfy notification with
# Review/Deny actions; if ntfy is unreachable it falls back to Telegram.
# ATLAS_NTFY_URL is your ntfy server base (e.g. https://ntfy.example.tailnet.ts.net);
# blank disables ntfy push entirely. ATLAS_NTFY_TOPIC defaults to eve-approvals.
# ATLAS_NTFY_DENY_URL is the POST endpoint the notification's Deny button hits.
ATLAS_NTFY_URL=
ATLAS_NTFY_TOPIC=eve-approvals
ATLAS_NTFY_DENY_URL=

# ---------- OpenJarvis server API key ----------
# The OpenJarvis daemon (:8000) enforces this Bearer key whenever it is bound to a
# non-loopback host (it refuses to start exposed without it). Generate one with
# `jarvis auth generate-key`. The sidecar's openjarvis_client falls back to this
# when ATLAS_AGENT_API_KEY is unset, so a single key configures both.
OPENJARVIS_API_KEY=

# ---------- AutoInvoice backend (invoice_tool + books_tool) ----------
# The AutoInvoice API on this box. invoice_tool (create_invoice) and books_tool
# (get_cash_pulse, list_unpaid_invoices, lookup_customer, create_lead) both read
# these. AUTOINVOICE_URL MUST stay loopback: the service token is only valid for
# the local AutoInvoice, and both tools REFUSE to send the bearer to a
# non-loopback host (127.0.0.0/8, ::1, or 'localhost' only — a tailnet 100.x or
# LAN IP counts as off-box and is refused). Default is http://localhost:4000.
# AUTOINVOICE_SERVICE_TOKEN is the Bearer the backend checks; leave blank and the
# tools refuse rather than call unauthenticated.
# AUTOINVOICE_URL=http://localhost:4000
# AUTOINVOICE_SERVICE_TOKEN=

# ---------- misc ----------
LOG_LEVEL=INFO

# ---------- instance ports (change ALL of these to run a second assistant on one box) ----------
# bot.py single-instance lock (a second copy exits code 111 instead of fighting for the mic).
ATLAS_LOCK_PORT=8764
# Loopback webhook app (SMS inbox + /agent/callback + the A2A inbound routes).
ATLAS_SMS_WEBHOOK_PORT=8787

# ---------- voice identity & trust tiers ----------
# Where enrolled voiceprints live. Give EACH assistant instance its own store —
# a shared default means one install's test enrollments leak into the other's.
# ATLAS_VOICEPRINTS=~/eve-voiceprints/profiles.json
# Cosine threshold for owner-voice match (raise to tighten, lower if your own
# voice gets rejected; enrolled-owner self-scores usually land 0.7-0.85).
# ATLAS_SPEAKER_THRESHOLD=0.55
# Spoken override code word: grants owner tier for 120s regardless of voice
# match. Overhearable — anyone who says it gets in. Leave blank to disable.
# ATLAS_OWNER_PHRASE=
# Extra spoken aliases that mean "me" when texting yourself (comma-separated).
# ATLAS_SELF_NAMES=

# ---------- audio pipeline ----------
# 1 = mic gated while the assistant speaks (no barge-in; use without AEC).
# 0 = full duplex (needs echo cancellation, e.g. libwebrtc-audio-processing).
# ATLAS_HALF_DUPLEX=0
# TTS engine: kokoro (in-process, instant) | chatterbox (server on :8004, voice cloning).
# ATLAS_TTS=kokoro
# ATLAS_TTS_BASE_URL=http://127.0.0.1:8004/v1
# ATLAS_TTS_VOICE=

# ---------- phone app pairing ----------
# Public base URL the pairing QR hands to the phone app (your tailnet HTTPS
# front for the approval API, e.g. from `tailscale serve`).
# ATLAS_APP_BASE_URL=https://your-host.your-tailnet.ts.net:8443

# ---------- per-user ritual data (gitignored personal files) ----------
# Copies of the tracked templates with YOUR content (see life_dashboard.json /
# priorities.json headers).
# ATLAS_LIFE_DASHBOARD=/path/to/life_dashboard.local.json
# ATLAS_PRIORITIES=/path/to/priorities.local.json

# ---------- phone capture inbox ----------
# Folder your phone syncs quick-capture notes into (e.g. Syncthing) + contacts CSV.
# ATLAS_INBOX_DIR=
# ATLAS_CONTACTS_CSV=

# ---------- texting backend: MacroDroid (alternative to SMS Gate above) ----------
# ATLAS_SMS_BACKEND=macrodroid
# MacroDroid webhook URL from your "send SMS" macro:
# ATLAS_MACRODROID_SEND_URL=https://trigger.macrodroid.com/<device-id>/<identifier>

# ---------- Wealth OS (business finance reads) ----------
# Comma-separated business slugs your Wealth OS instance serves. REQUIRED for
# the wealth tools — unset, they refuse loudly rather than guess.
# WEALTH_OS_BUSINESS_SLUGS=my-company,my-other-company

# ---------- ResearchOS (autonomous product research service) ----------
# Base URL of YOUR ResearchOS instance. Unset => research tools refuse loudly.
# RESEARCHOS_URL=
