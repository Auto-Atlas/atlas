<!-- Atlas brand mark: a geometric flat-top hexagon ring with a center dot ("watching eye" motif).
     Single white fill on a 24x24 viewport so complications/tiles TINT it correctly. Real shippable
     asset (not a placeholder). Ring uses evenOdd fill (outer hexagon minus inner hexagon). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- No android:tint: a monochrome asset lets its consumer (complication renderer / tile) tint it. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M21,12 L16.5,19.79 L7.5,19.79 L3,12 L7.5,4.21 L16.5,4.21 Z M18,12 L15,17.196 L9,17.196 L6,12 L9,6.804 L15,6.804 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,9.8 a2.2,2.2 0 1 1 0,4.4 a2.2,2.2 0 1 1 0,-4.4 z" />
</vector>
