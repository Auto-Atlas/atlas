<?xml version="1.0" encoding="utf-8"?>
<!--
  EVE watch launcher foreground. Reuses the brand mark geometry from ic_eve_mark.xml (the
  "watching eye" hexagon ring + centre dot, authored on a 24x24 grid) scaled into the 108x108
  adaptive-icon canvas and centred inside the 66dp safe circle the round Wear launcher masks to.
  Ring is the EVE accent teal (#2DD4BF), the pupil is white — legible on the dark adaptive
  background layer (@color/ic_launcher_background). Real shippable asset, not a placeholder.

  Transform: scale 2.5, translate 24 -> the 24-grid centre (12,12) lands on (54,54); the hexagon
  spans ~45dp (radius ~22.5dp), comfortably inside the 66dp safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="2.5"
        android:scaleY="2.5"
        android:translateX="24"
        android:translateY="24">
        <!-- Hexagon ring (outer minus inner via evenOdd) -->
        <path
            android:fillColor="#2DD4BF"
            android:fillType="evenOdd"
            android:pathData="M21,12 L16.5,19.79 L7.5,19.79 L3,12 L7.5,4.21 L16.5,4.21 Z M18,12 L15,17.196 L9,17.196 L6,12 L9,6.804 L15,6.804 Z" />
        <!-- Pupil -->
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M12,9.8 a2.2,2.2 0 1 1 0,4.4 a2.2,2.2 0 1 1 0,-4.4 z" />
    </group>
</vector>
